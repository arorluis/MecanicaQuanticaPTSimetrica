        RowBox[{
         RowBox[{"{", 
          RowBox[{"HAM2", ",", 
           RowBox[{"DirichletCondition", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"FI", "[", "x", "]"}], "==", "0"}], ",", "True"}], 
            "]"}]}], "}"}], ",", 
