          RowBox[{
           RowBox[{"\"\<ReducedPlanckConstant\>\"", "->", "1"}], ",", 
           RowBox[{"\"\<SchrodingerPotential\>\"", "->", 
            RowBox[{
             RowBox[{"x", "^", "2"}], 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"I", "*", "x"}], ")"}], "^", "eps"}]}]}], ",", 
           RowBox[{"\"\<Mass\>\"", "->", 
            FractionBox["1", "2"]}]}], "|>"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"vals2", ",", "funs2"}], "}"}], "=", 
