 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"eps", "=", 
       RowBox[{
        RowBox[{"epsRange", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "+", 
        RowBox[{"iStep", "*", "epsStep"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"HAM2", "=", 
