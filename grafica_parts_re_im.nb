            RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "Neig", ",", 
         RowBox[{"Method", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"\"\<PDEDiscretization\>\"", "->", 
            RowBox[{"{", 
