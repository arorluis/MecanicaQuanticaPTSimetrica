 RowBox[{
  RowBox[{"(*", "Definicions", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"centroDerecha", "[", "eps_", "]"}], ":=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"Pi", "*", "eps"}], ")"}]}], "/", 
      RowBox[{"(", 
       RowBox[{"8", "+", 
        RowBox[{"2", "*", "eps"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"centroIzquierda", "[", "eps_", "]"}], ":=", 
     RowBox[{
      RowBox[{"-", "Pi"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Pi", "*", "eps"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"8", "+", 
         RowBox[{"2", "*", "eps"}]}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"amplitud", "[", "eps_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", "*", "Pi"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"4", "+", "eps"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"xParam", "[", 
      RowBox[{"t_", ",", "eps_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"-", "I"}], "*", 
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"t", "^", "2"}]}], ")"}]}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", "Pi", "*", "I", "*", "t"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"4", "+", "eps"}], ")"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eps", "=", "0"}], ";"}], " ", "\[IndentingNewLine]", "\n", 
