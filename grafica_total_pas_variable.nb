Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"Neig", "=", "21"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"eta", "=", 
    RowBox[{"10", "^", 
     RowBox[{"-", "3"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"epsList", "=", 
   RowBox[{"Union", "[", 
    RowBox[{
     RowBox[{"Range", "[", 
      RowBox[{
       RowBox[{"-", "0.99"}], ",", "0", ",", "0.01"}], "]"}], ",", 
     RowBox[{"(*", 
      RowBox[{"pas", " ", "xicotet", " ", "zona", " ", "cr\[IAcute]tica"}], 
      "*)"}], 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "5", ",", "0.1"}], "]"}]}], "    ", 
    RowBox[{"(*", 
     RowBox[{
     "Pas", " ", "normal", " ", "per", " ", "a", " ", "la", " ", "resta"}], 
     "*)"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Neps", "=", 
    RowBox[{"Length", "[", "epsList", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"xParam", "[", 
     RowBox[{"t_", ",", "eps_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"-", "I"}], "*", 
     RowBox[{"(", 
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"t", "^", "2"}]}], ")"}]}], ")"}], "*", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "*", "Pi", "*", "I", "*", "t"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "+", "eps"}], ")"}]}], "]"}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"cam\[IAcute]", " ", "param"}], "*)"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"res", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "Neig"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"eps", "=", 
       RowBox[{"epsList", "[", 
        RowBox[{"[", "iStep", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"HAM", "=", 
       RowBox[{"Block", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"tVar", ",", "xp", ",", "xpp", ",", "pot"}], "}"}], ",", 
         RowBox[{
          RowBox[{"xp", "=", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"xParam", "[", 
              RowBox[{"tVar", ",", "eps"}], "]"}], ",", "tVar"}], "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"xpp", "=", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"xParam", "[", 
              RowBox[{"tVar", ",", "eps"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"tVar", ",", "2"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"pot", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"xParam", "[", 
               RowBox[{"tVar", ",", "eps"}], "]"}], "^", "2"}], ")"}], "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"I", "*", 
               RowBox[{"xParam", "[", 
                RowBox[{"tVar", ",", "eps"}], "]"}]}], ")"}], "^", 
             "eps"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{"1", "/", 
                 RowBox[{"xp", "^", "2"}]}], ")"}]}], "*", 
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"FI", "[", "t", "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"t", ",", "2"}], "}"}]}], "]"}]}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"xpp", "/", 
                RowBox[{"xp", "^", "3"}]}], ")"}], "*", 
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"FI", "[", "t", "]"}], ",", "t"}], "]"}]}], "+", 
             RowBox[{"pot", "*", 
              RowBox[{"FI", "[", "t", "]"}]}]}], ")"}], "/.", " ", 
           RowBox[{"tVar", "->", "t"}]}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"vals", ",", "funs"}], "}"}], "=", 
       RowBox[{"NDEigensystem", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"HAM", ",", 
           RowBox[{"DirichletCondition", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"FI", "[", "t", "]"}], "==", "0"}], ",", "True"}], 
            "]"}]}], "}"}], ",", 
         RowBox[{"FI", "[", "t", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "eta"}], ",", 
           RowBox[{"1", "-", "eta"}]}], "}"}], ",", "Neig", ",", 
         RowBox[{"Method", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<PDEDiscretization\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<FiniteElement\>\"", ",", 
              RowBox[{"{", 
               RowBox[{"\"\<MeshOptions\>\"", "->", 
                RowBox[{"{", 
                 RowBox[{"\"\<MaxCellMeasure\>\"", "->", "0.002"}], "}"}]}], 
               "}"}]}], "}"}]}], "}"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sortedVals", "=", 
       RowBox[{"SortBy", "[", 
        RowBox[{"vals", ",", "Abs"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{
          RowBox[{"res", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"eps", ",", 
            RowBox[{"Chop", "[", 
             RowBox[{
              RowBox[{"sortedVals", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", 
              RowBox[{"10", "^", 
               RowBox[{"-", "4"}]}]}], "]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "Neig"}], "}"}]}], "]"}], ";"}], ",", 
     RowBox[{"{", 
      RowBox[{"iStep", ",", "1", ",", "Neps"}], "}"}]}], "]"}], ";"}], 
  " "}]}], "Input",
